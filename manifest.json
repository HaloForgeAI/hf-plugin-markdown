{
  "$schema": "https://haloforge.dev/schemas/plugin/v1.json",
  "id": "dev.haloforge.markdown",
  "name": "Markdown Workspace",
  "version": "0.2.5",
  "description": "AI-native Markdown reader workspace with recent files, document context, and an embedded assistant panel.",
  "long_description": "Adds a top-level Markdown module to HaloForge so enabled users can open Markdown files from the sidebar, preview them with high-quality rendering, keep a recent-file list, and use a context-aware AI reading panel designed to evolve into a full editor workflow.",
  "author": "HaloForge Team",
  "homepage": "https://haloforge.link/catalog/plugins/markdown",
  "license": "MIT",
  "keywords": ["markdown", "reader", "knowledge", "ai"],
  "icon": "assets/icon.png",
  "compatibility": {
    "min_app_version": "0.6.0",
    "min_host_api_version": "0.1.0",
    "platforms": ["windows", "macos", "linux"]
  },
  "host_capabilities": ["navigation", "file_intents", "file_dialogs", "aichat", "theme_read", "event_subscribe", "deep_links"],
  "capability_levels": [0],
  "integration": {
    "level0": {
      "module_id": "markdown",
      "module_label": "Markdown",
      "module_icon": "FilePenLine",
      "sidebar_position": "main",
      "sidebar_order": 30,
      "panel_entry": "frontend/index.js"
    }
  },
  "entry": {
    "native": {
      "macos_arm64": "native/aarch64-apple-darwin.dylib",
      "macos_x64": "native/x86_64-apple-darwin.dylib",
      "windows_x64": "native/x86_64-pc-windows-msvc.dll",
      "windows_arm64": "native/aarch64-pc-windows-msvc.dll",
      "linux_x64": "native/x86_64-unknown-linux-gnu.so",
      "linux_arm64": "native/aarch64-unknown-linux-gnu.so"
    },
    "frontend": "frontend/index.js",
    "frontend_styles": "frontend/styles.css"
  },
  "permissions": [
    { "type": "ipc_register" },
    { "type": "filesystem_read" },
    { "type": "filesystem_write" },
    { "type": "database_create_tables" },
    { "type": "host_navigation" },
    { "type": "host_file_intents" },
    { "type": "host_file_dialogs" },
    { "type": "host_aichat_access" },
    { "type": "host_theme_read" },
    { "type": "host_event_subscribe" },
    { "type": "host_deep_links" }
  ],
  "settings_schema": {
    "type": "object",
    "properties": {
      "default_reader_theme": {
        "type": "string",
        "title": "Default reader theme",
        "default": "paper"
      },
      "max_context_chars": {
        "type": "number",
        "title": "Maximum document context characters",
        "default": 14000,
        "minimum": 4000,
        "maximum": 40000
      }
    }
  },
  "commands": [
    { "id": "md_recent_files", "description": "List recently opened Markdown files" },
    { "id": "md_open_file", "description": "Open a Markdown file and persist it in recents" },
    { "id": "md_create_file", "description": "Create a Markdown file and open it" },
    { "id": "md_save_file", "description": "Save a Markdown file and refresh document metadata" },
    { "id": "md_remove_recent_file", "description": "Remove a Markdown file from recents" },
    { "id": "md_save_image", "description": "Save an embedded Markdown image beside the current document" }
  ]
}
